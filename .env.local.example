# Supabase — copie este arquivo para .env.local e preencha com as chaves do SEU projeto.
# Onde achar: Supabase -> seu projeto -> Settings -> API.
# NUNCA versione o .env.local (ja esta no .gitignore).

# Project URL
NEXT_PUBLIC_SUPABASE_URL=

# anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (Opcional, so quando precisar de acesso privilegiado NO SERVIDOR)
# NUNCA use no client; NUNCA versione.
# SUPABASE_SERVICE_ROLE_KEY=

# E-mail transacional (Brevo) — para convites e a régua de comissão
BREVO_API_KEY=
EMAIL_FROM=quotaria@contadorx.com.br
EMAIL_FROM_NAME=Quotaria

# Pagamentos (Asaas) — cobrança recorrente das assinaturas
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=

# IA — leitura do consultor no diagnóstico (e assistente de suporte)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
